{{#*inline "body"}}
{{#with post}}

<main id="gh-main" class="gh-main">
    <article class="gh-article {{post_class}}">

        <header class="gh-article-header gh-canvas">
            <span class="gh-article-meta">
                By {{#foreach authors}}{{#if @first}}{{name}}{{else}}, {{name}}{{/if}}{{/foreach}}
                {{#if primary_tag}}
                    in
                    <a class="gh-article-tag" href="{{primary_tag.url}}">{{primary_tag.name}}</a>
                {{/if}}
                —
                <time datetime="{{date published_at format="YYYY-MM-DD"}}">{{date published_at format="DD MMM YYYY"}}</time>
            </span>

            <h1 class="gh-article-title">{{title}}</h1>

            {{#if custom_excerpt}}
                <p class="gh-article-excerpt">{{custom_excerpt}}</p>
            {{/if}}

            {{> partials/feature-image}}
        </header>

        <div class="gh-content gh-canvas">
            {{{content}}}
        </div>

        {{#if comments}}
            <div class="gh-comments gh-canvas">
                {{comments}}
            </div>
        {{/if}}

        <footer class="gh-article-footer gh-canvas{{#if @root.site.comments_enabled}}{{#unless @root.member}} no-border{{/unless}}{{#unless access}} no-border{{/unless}}{{/if}}">
            <nav class="gh-navigation">
                <div class="gh-navigation-previous">
                    {{#with prev_post}}
                        <a class="gh-navigation-link" href="/{{slug}}">
                            <span class="gh-navigation-label">{{> partials/icons/arrow-left}} Previous issue</span>
                            <h4 class="gh-navigation-title">{{title}}</h4>
                        </a>
                    {{/with}}
                </div>

                <div class="gh-navigation-middle"></div>

                <div class="gh-navigation-next">
                    {{#with next_post}}
                        <a class="gh-navigation-link" href="/{{slug}}">
                            <span class="gh-navigation-label">Next issue {{> partials/icons/arrow-right}}</span>
                            <h4 class="gh-navigation-title">{{title}}</h4>
                        </a>
                    {{/with}}
                </div>
            </nav>
        </footer>

    </article>
</main>

{{/with}}
{{/inline}}
{{> default}}